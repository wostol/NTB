// services/booking-service/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Computer — таблица в БД: "Computer" (с большой буквы) =====
model Computer {
  computer_id   Int       @id @default(autoincrement())
  serial_number String    @unique @db.VarChar(50)
  floor         Int
  room          String    @db.VarChar(20)
  status        String    @db.VarChar(20) @default("available")
  
  bookings      Booking[]

  @@map("Computer")  // ✅ С БОЛЬШОЙ БУКВЫ!
}

// ===== Booking — таблица в БД: "Booking" (с большой буквы) =====
model Booking {
  booking_id    Int       @id @default(autoincrement())
  user_id       Int
  computer_id   Int
  booking_date  DateTime
  start_time    DateTime
  end_time      DateTime
  status        String    @db.VarChar(20)
  booking_type  String?   @db.VarChar(20)
  purpose       String?   @db.VarChar(255)
  created_at    DateTime  @default(now())
  cancelled_at  DateTime?
  notes         String?   @db.Text
  
  computer      Computer  @relation(fields: [computer_id], references: [computer_id], onDelete: Cascade)
  sessions      Session[]

  @@map("Booking")  // ✅ С БОЛЬШОЙ БУКВЫ!
}

// ===== Session — таблица в БД: "Session" (с большой буквы) =====
model Session {
  session_id  Int       @id @default(autoincrement())
  booking_id  Int
  user_id     Int
  computer_id Int
  start_time  DateTime
  end_time    DateTime?
  status      String    @db.VarChar(20)
  created_at  DateTime  @default(now())

  booking     Booking   @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)

  @@map("Session")  // ✅ С БОЛЬШОЙ БУКВЫ!
}