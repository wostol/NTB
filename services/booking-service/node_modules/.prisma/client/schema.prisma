generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Computer {
  computer_id      Int       @id @default(autoincrement())
  serial_number    String    @unique @db.VarChar(50)
  floor            Int
  room             String    @db.VarChar(20)
  status           String    @default("available") @db.VarChar(20)
  last_maintenance DateTime?
  bookings         Booking[]
}

model Booking {
  booking_id   Int       @id @default(autoincrement())
  user_id      Int
  computer_id  Int
  booking_date DateTime
  start_time   DateTime
  end_time     DateTime
  status       String    @db.VarChar(20)
  booking_type String?   @db.VarChar(20)
  purpose      String?   @db.VarChar(255)
  created_at   DateTime  @default(now())
  cancelled_at DateTime?
  notes        String?   @db.Text

  computer Computer @relation(fields: [computer_id], references: [computer_id])
}
