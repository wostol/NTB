generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique @db.VarChar(50)
  users     User[]
}

model User {
  user_id    Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(50)
  full_name  String    @db.VarChar(100)
  email      String?   @unique @db.VarChar(100)
  role_id    Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  last_login DateTime?

  role         Role          @relation(fields: [role_id], references: [role_id])
  bookings     Booking[]
  sessions     Session[]
  favorites    Favorite[]
  filters      Filter[]
  audit_logs   AuditLog[]
  waiting_list WaitingList[]
}

model Computer {
  computer_id      Int       @id @default(autoincrement())
  serial_number    String    @unique @db.VarChar(50)
  floor            Int
  room             String    @db.VarChar(20)
  status           String    @default("available") @db.VarChar(20)
  last_maintenance DateTime?

  // Связь 1:1. Внешний ключ хранится в PcConfiguration
  config PcConfiguration?

  bookings     Booking[]
  sessions     Session[]
  waiting_list WaitingList[]
  favorites    Favorite[]
  pc_software  PcSoftware[]
}

model PcConfiguration {
  id          Int      @id @default(autoincrement())
  computer_id Int      @unique
  computer    Computer @relation(fields: [computer_id], references: [computer_id])

  cpu          String? @db.VarChar(100)
  ram_gb       Int?
  storage_gb   Int?
  storage_type String? @db.VarChar(10)
  gpu          String? @db.VarChar(100)
  os           String? @db.VarChar(50)
  monitor      String? @db.VarChar(50)
  notes        String? @db.Text
}

model Software {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100)
  version      String?      @db.VarChar(50)
  category     String?      @db.VarChar(50)
  license_type String?      @db.VarChar(50)
  description  String?      @db.Text
  created_at   DateTime     @default(now())
  pc_software  PcSoftware[]
}

model PcSoftware {
  pc_id          Int
  software_id    Int
  installed_date DateTime @default(now())

  computer Computer @relation(fields: [pc_id], references: [computer_id])
  software Software @relation(fields: [software_id], references: [id])

  @@id([pc_id, software_id])
}

model Booking {
  booking_id   Int       @id @default(autoincrement())
  user_id      Int
  computer_id  Int
  booking_date DateTime
  start_time   DateTime
  end_time     DateTime
  status       String    @db.VarChar(20)
  booking_type String?   @db.VarChar(20)
  purpose      String?   @db.VarChar(255)
  created_at   DateTime  @default(now())
  cancelled_at DateTime?
  notes        String?   @db.Text

  user     User      @relation(fields: [user_id], references: [user_id])
  computer Computer  @relation(fields: [computer_id], references: [computer_id])
  sessions Session[]
}

model Session {
  session_id  Int       @id @default(autoincrement())
  user_id     Int
  computer_id Int
  booking_id  Int
  start_time  DateTime
  end_time    DateTime?
  status      String    @db.VarChar(20)
  created_at  DateTime  @default(now())

  user     User     @relation(fields: [user_id], references: [user_id])
  computer Computer @relation(fields: [computer_id], references: [computer_id])
  booking  Booking  @relation(fields: [booking_id], references: [booking_id])
}

model WaitingList {
  id                 Int       @id @default(autoincrement())
  user_id            Int
  computer_id        Int
  desired_start_time DateTime?
  priority           Int       @default(0)
  created_at         DateTime  @default(now())
  notified           Boolean   @default(false)
  expires_at         DateTime?

  user     User     @relation(fields: [user_id], references: [user_id])
  computer Computer @relation(fields: [computer_id], references: [computer_id])
}

model Favorite {
  user_id     Int
  computer_id Int
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [user_id])
  computer Computer @relation(fields: [computer_id], references: [computer_id])

  @@id([user_id, computer_id])
}

model Filter {
  filter_id             Int      @id @default(autoincrement())
  user_id               Int
  config_requirements   Json?
  software_requirements Json?
  created_at            DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id])
}

model AuditLog {
  log_id      BigInt   @id @default(autoincrement())
  user_id     Int?
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(50)
  entity_id   Int?
  old_value   Json?
  new_value   Json?
  ip_address  String?  @db.VarChar(50)
  created_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [user_id])
}
